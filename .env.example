# Required: feedback API origin (no trailing slash). App throws a clear error if missing.
VITE_FEEDBACK_API_BASE_URL=http://ifsc.test

# Required: path to getFeedbackPanelItems (leading slash recommended).
VITE_FEEDBACK_PANEL_ITEMS_PATH=/api/feedback/getFeedbackPanelItems

# Optional: S3/CDN base for relative panel asset paths (see getAwsResourceBaseUrl()).
VITE_AWS_RESOURCE_BASE_URL=https://simpple-stage-resources.s3.ap-southeast-1.amazonaws.com
